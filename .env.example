# ══════════════════════════════════════════════════════════════════════════════
#  Curalink — Environment Variables Template
#  Copy this file to backend/.env and fill in your values.
#
#  LLM Architecture: Self-hosted open-source only
#    Primary:  LLaMA 3.1 8B via Ollama
#    Fallback: Mistral 7B via HuggingFace Dedicated Endpoint
#    Removed:  Groq (external black-box API — violates self-control requirement)
# ══════════════════════════════════════════════════════════════════════════════

# ─── Database ─────────────────────────────────────────────────────────────────
# Local:  mongodb://localhost:27017/curalink
# Atlas:  mongodb+srv://user:pass@cluster.mongodb.net/curalink
MONGO_URI=mongodb://localhost:27017/curalink
PORT=5000

# ─── Ollama Server ────────────────────────────────────────────────────────────
# Shared URL for both expansion and reasoning models.
# Local dev:  http://localhost:11434
# Remote:     http://your-ollama-server:11434
OLLAMA_URL=http://localhost:11434

# ─── Stage 1: Query Expansion Model ──────────────────────────────────────────
# Used ONLY for generating search query variants. Fast, short context.
# Can be a smaller model than the reasoning model to save RAM.
#
# Recommended values:
#   llama3.1:8b   — best quality, ~5GB RAM
#   llama3.2:3b   — faster, ~2GB RAM (acceptable for query expansion)
OLLAMA_EXPANSION_MODEL=llama3.1:8b

# ─── Stage 4: Primary Reasoning Model — LLaMA 3 (Ollama) ────────────────────
# WHY LLAMA 3:
#   Open-source (Meta), self-hosted, no external API dependency.
#   Full control over inference, no data leaves your infrastructure.
#   Instruction-tuned variant follows strict JSON output format reliably.
#
# Setup:
#   1. Install Ollama: https://ollama.com/download
#   2. Pull model:     ollama pull llama3.1:8b
#   3. Start server:   ollama serve
#
# Options by hardware:
#   llama3.1:8b      — 8GB RAM/VRAM, good quality     (recommended default)
#   llama3.1:70b     — 40GB VRAM, excellent quality   (if you have the hardware)
#   llama3.2:3b      — 3GB RAM, lower quality         (minimal hardware)
OLLAMA_REASONING_MODEL=llama3.1:8b

# Alias kept for compatibility
OLLAMA_MODEL=llama3.1:8b

# ─── Stage 4: Fallback Reasoning Model — Mistral 7B (HF Dedicated Endpoint) ──
# WHY DEDICATED ENDPOINT (not the shared HF inference API):
#   - Dedicated = your own container, no cold starts, streaming via TGI
#   - Shared API = unreliable, rate-limited, 30s+ cold starts
#   - Mistral 7B is Apache 2.0 open-source — no licence restrictions
#
# Setup (takes ~5 minutes):
#   1. Go to: https://huggingface.co/inference-endpoints
#   2. New endpoint → Model: mistralai/Mistral-7B-Instruct-v0.2
#   3. Choose hardware (1× T4 16GB works well)
#   4. Paste the generated URL below
#
# Leave blank to skip this fallback (circuit breaker will handle failure).
HF_ENDPOINT_URL=https://your-endpoint-name.endpoints.huggingface.cloud
HF_FALLBACK_MODEL=mistralai/Mistral-7B-Instruct-v0.2
HF_TOKEN=your_huggingface_token_here

# ─── Retrieval APIs ───────────────────────────────────────────────────────────
# PubMed: optional key → 10× higher rate limit (free at ncbi.nlm.nih.gov/account)
PUBMED_API_KEY=

# ─── App Config ───────────────────────────────────────────────────────────────
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# ══════════════════════════════════════════════════════════════════════════════
# QUICK START
# ══════════════════════════════════════════════════════════════════════════════
# Minimum setup (Ollama only, no HF endpoint):
#   1. Install Ollama: https://ollama.com/download
#   2. ollama pull llama3.1:8b
#   3. ollama serve
#   4. Set MONGO_URI (local or Atlas)
#   5. npm run dev
#
# Production setup (Ollama primary + HF dedicated fallback):
#   1. Deploy Ollama on a VPS/cloud server with GPU
#   2. Set OLLAMA_URL to your server's address
#   3. Spin up HF dedicated endpoint for Mistral 7B
#   4. Set HF_ENDPOINT_URL + HF_TOKEN
#   5. Set MONGO_URI to Atlas
#   6. Deploy backend to Railway/Render/Fly.io
# ══════════════════════════════════════════════════════════════════════════════

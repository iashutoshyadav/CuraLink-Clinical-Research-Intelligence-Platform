# ─── Database ──────────────────────────────────────────────────────────────────
MONGO_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/?appName=Curalink
PORT=5000

# ─── Stage 1: Query Expansion ──────────────────────────────────────────────────
# Ollama only used locally — in production falls back to rule-based expansion
OLLAMA_URL=http://localhost:11434
OLLAMA_EXPANSION_MODEL=llama3.2:3b

# ─── Stage 4: LLM Reasoning (Primary — Groq Cloud) ─────────────────────────────
# Get free key at: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# ─── Stage 4: LLM Reasoning (Backup — Ollama local only) ───────────────────────
OLLAMA_REASONING_MODEL=mistral:7b
OLLAMA_FALLBACK_MODELS=llama3.2:3b,llama3.1:8b
OLLAMA_MODEL=llama3.2:3b

# ─── Stage 4: HuggingFace Endpoint (optional) ──────────────────────────────────
HF_ENDPOINT_URL=
HF_FALLBACK_MODEL=mistralai/Mistral-7B-Instruct-v0.2
HF_TOKEN=

# ─── Retrieval API Keys ─────────────────────────────────────────────────────────
# Free key at: https://www.ncbi.nlm.nih.gov/account/
# Increases PubMed rate limit from 3 req/s → 10 req/s
PUBMED_API_KEY=your_pubmed_api_key_here

# ─── App Config ─────────────────────────────────────────────────────────────────
NODE_ENV=production
FRONTEND_URL=https://your-app.vercel.app
